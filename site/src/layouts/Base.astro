---
import { locales, type Locale } from "../i18n/ui";
const { lang, title, description } = Astro.props as { lang: Locale; title: string; description: string };
const SITE = "https://credentialcommons.org";
const pathFor = (l: Locale) => (l === "en" ? `${SITE}/` : `${SITE}/${l}/`);
const canonical = pathFor(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": `${SITE}/#software`,
      name: "Credential Commons",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Node.js",
      url: `${SITE}/`,
      codeRepository: "https://github.com/credential-commons/credential-commons",
      description,
      inLanguage: lang,
      license: "https://www.apache.org/licenses/LICENSE-2.0",
      offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
      keywords: ["credential", "micro-credential", "learning outcome", "Linked Data", "JSON-LD", "SHACL", "CTDL", "ELM", "Open Badges", "interoperability"],
    },
    { "@type": "DefinedTermSet", "@id": `${SITE}/ns/0.1/`, name: "Credential Commons vocabulary (cc:)", url: `${SITE}/ns/0.1/` },
    {
      "@type": "Dataset",
      "@id": `${SITE}/#reference-dataset`,
      name: "mkval micro-qualification reference dataset",
      description: "250 real Estonian micro-qualifications published as Credential Commons-conformant JSON-LD.",
      license: "https://creativecommons.org/licenses/by/4.0/",
      isAccessibleForFree: true,
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {locales.map((l) => <link rel="alternate" hreflang={l} href={pathFor(l)} />)}
  <link rel="alternate" hreflang="x-default" href={`${SITE}/`} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="robots" content="index,follow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <style is:global>
    :root { --ink:#12212e; --teal:#2f9e95; --muted:#5a6b80; --line:#dbe4ee; }
    * { box-sizing: border-box; }
    body { margin:0; font:16px/1.6 system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif; color:var(--ink); }
    .wrap { max-width:760px; margin:0 auto; padding:40px 20px; }
    h1 { font-size:2rem; margin:0 0 8px; }
    .lede { font-size:1.15rem; color:var(--muted); margin:0 0 26px; }
    pre { background:#0f1b24; color:#e6edf3; padding:14px 16px; border-radius:10px; overflow-x:auto; font-size:.9rem; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
    a { color:var(--teal); font-weight:600; text-decoration:none; }
    a:hover { text-decoration:underline; }
    .grid { display:grid; gap:12px; grid-template-columns:1fr 1fr; margin:22px 0; }
    .card { border:1px solid var(--line); border-radius:12px; padding:14px 16px; }
    .card h3 { margin:0 0 4px; font-size:1rem; }
    .card p { margin:0; color:var(--muted); font-size:.92rem; }
    nav.langs { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:22px; font-size:.9rem; }
    footer { margin-top:34px; padding-top:16px; border-top:1px solid var(--line); color:var(--muted); font-size:.88rem; }
    .tag { display:inline-block; background:#eaf6f4; color:#1f6f68; border-radius:999px; padding:2px 10px; font-size:.8rem; font-weight:700; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
