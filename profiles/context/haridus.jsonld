{
  "@context": {
    "@version": 1.1,
    "cc": "https://credentialcommons.org/ns/0.1/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "haridus": "https://schema.edu.ee/0.1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "MicroCredential": "cc:MicroCredential",
    "Curriculum": "cc:Curriculum",
    "Organization": "schema:Organization",

    "name": "schema:name",
    "url": { "@id": "schema:url", "@type": "@id" },
    "summary": "schema:description",
    "field": "cc:field",
    "language": "dcterms:language",

    "provider": "schema:provider",

    "ectsCredits": { "@id": "cc:ectsCredits", "@type": "xsd:decimal" },
    "academicHours": { "@id": "cc:academicHours", "@type": "xsd:decimal" },
    "clockHours": { "@id": "cc:clockHours", "@type": "xsd:decimal" },
    "learningOutcome": "cc:learningOutcome",
    "entryRequirements": "cc:entryRequirements",
    "content": "cc:content",
    "awardedCredential": "cc:awardedCredential",
    "level": "cc:level",

    "price": "cc:price",
    "priceCurrency": "cc:priceCurrency",
    "registrationDeadline": { "@id": "cc:registrationDeadline", "@type": "xsd:date" },
    "startDate": { "@id": "schema:startDate", "@type": "xsd:date" }
  }
}
