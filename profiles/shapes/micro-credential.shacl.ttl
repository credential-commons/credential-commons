# Credential Commons — Micro-credential profile (v0.1)
#
# A SHACL profile: it does NOT define a new ontology, it constrains how existing
# terms (schema.org, schema.edu.ee `haridus:`, dcterms) must be used to describe
# a micro-credential / micro-qualification so the data is interoperable.
#
# Severity:
#   sh:Violation = MUST fix (data is non-conformant)
#   sh:Warning   = SHOULD add (conformant, but weaker for findability/reuse)

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix cc:      <https://credentialcommons.org/ns/0.1/> .
@prefix schema:  <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

cc:MicroCredentialShape
    a sh:NodeShape ;
    sh:targetClass cc:MicroCredential ;
    rdfs:label "Micro-credential profile" ;

    # --- Required (Violation) ---
    sh:property [
        sh:path schema:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
        sh:message "A micro-credential MUST have a name (schema:name)." ;
    ] ;
    sh:property [
        sh:path cc:ectsCredits ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "ECTS/EAP credit value is REQUIRED (cc:ectsCredits)." ;
    ] ;
    sh:property [
        sh:path dcterms:language ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Language is REQUIRED (dcterms:language, BCP-47 e.g. \"et\")." ;
    ] ;
    sh:property [
        sh:path schema:provider ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "A provider is REQUIRED (schema:provider -> an Organization with schema:name)." ;
    ] ;

    # --- Recommended (Warning) ---
    sh:property [
        sh:path schema:url ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Recommended: a public landing URL (schema:url)." ;
    ] ;
    sh:property [
        sh:path cc:learningOutcome ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Recommended: at least one learning outcome (cc:learningOutcome ~ haridus:Opivaljund)." ;
    ] ;
    sh:property [
        sh:path cc:field ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Recommended: a subject field (cc:field)." ;
    ] .
